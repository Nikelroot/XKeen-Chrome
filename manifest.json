{
  "manifest_version": 3,
  "name": "XKeen Domain Router",
  "description": "Добавляет домен текущей вкладки в список маршрутизации XKeen/Xray.",
  "version": "0.1.0",
  "action": {
    "default_title": "XKeen Domain Router",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
